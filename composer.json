{
    "name": "adriengras/umami-php",
    "description": "Client PHP transport-only pour l'API Umami Analytics (v3.1.0), bâti sur Saloon v4.",
    "type": "library",
    "license": "MIT",
    "keywords": ["umami", "analytics", "saloon", "http-client", "tracking"],
    "homepage": "https://github.com/AdrienGras/umami-php",
    "authors": [
        {
            "name": "Adrien Gras",
            "homepage": "https://github.com/AdrienGras"
        }
    ],
    "support": {
        "issues": "https://github.com/AdrienGras/umami-php/issues",
        "source": "https://github.com/AdrienGras/umami-php"
    },
    "require": {
        "php": "^8.2",
        "saloonphp/saloon": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "AdrienGras\\Umami\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AdrienGras\\Umami\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
